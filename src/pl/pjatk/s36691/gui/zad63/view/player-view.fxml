<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="pl.pjatk.s36691.gui.zad63.controller.PlayerController"
            prefWidth="1200"
            prefHeight="650"
            styleClass="player-root">

    <top>
        <VBox styleClass="top-panel">
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="header-row">
                <Label text="AUDIO DECK" styleClass="app-title" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="FXML MUSIC PLAYER" styleClass="app-subtitle" />
            </HBox>

            <VBox styleClass="now-playing-box">
                <Label text="NOW PLAYING" styleClass="section-caption" />
                <Label fx:id="nowPlayingLabel"
                       text="No track selected"
                       styleClass="now-playing-label" />

                <HBox alignment="CENTER" spacing="10" styleClass="progress-row">
                    <Label fx:id="currentTimeLabel"
                           text="00:00"
                           styleClass="time-label" />

                    <Slider fx:id="progressSlider"
                            min="0"
                            max="100"
                            value="0"
                            HBox.hgrow="ALWAYS" />

                    <Label fx:id="totalTimeLabel"
                           text="00:00"
                           styleClass="time-label" />
                </HBox>
            </VBox>
        </VBox>
    </top>

    <left>
        <VBox styleClass="side-panel">
            <Label text="CATEGORIES" styleClass="section-caption" />
            <ListView fx:id="categoriesListView"
                      prefWidth="190"
                      styleClass="categories-list" />
        </VBox>
    </left>

    <center>
        <VBox styleClass="center-panel">
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="search-row">
                <Label text="SEARCH" styleClass="field-label" />
                <TextField fx:id="searchField"
                           promptText="title / album / artist"
                           HBox.hgrow="ALWAYS"
                           styleClass="search-field" />
            </HBox>

            <TableView fx:id="songsTableView"
                       VBox.vgrow="ALWAYS"
                       styleClass="songs-table">
                <columns>
                    <TableColumn fx:id="titleColumn"
                                 text="TITLE"
                                 prefWidth="200" />
                    <TableColumn fx:id="artistColumn"
                                 text="ARTIST"
                                 prefWidth="190" />
                    <TableColumn fx:id="albumColumn"
                                 text="ALBUM"
                                 prefWidth="190" />
                    <TableColumn fx:id="categoryColumn"
                                 text="CATEGORY"
                                 prefWidth="100" />
                </columns>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <VBox styleClass="bottom-panel">
            <Separator styleClass="neon-separator" />

            <HBox alignment="CENTER" spacing="18" styleClass="controls-row">
                <Button fx:id="playPauseButton"
                        text="▶"
                        mnemonicParsing="false"
                        styleClass="control-button">
                    <tooltip>
                        <Tooltip text="Play / Pause" />
                    </tooltip>
                </Button>

                <Button fx:id="stopButton"
                        text="■"
                        mnemonicParsing="false"
                        styleClass="control-button">
                    <tooltip>
                        <Tooltip text="Stop" />
                    </tooltip>
                </Button>

                <ToggleButton fx:id="shuffleButton"
                        text="⇄"
                        mnemonicParsing="false"
                        styleClass="control-button">
                    <tooltip>
                        <Tooltip text="Shuffle" />
                    </tooltip>
                </ToggleButton>

                <ToggleButton fx:id="loopToggleButton"
                              text="↻"
                              mnemonicParsing="false"
                              styleClass="control-button">
                    <tooltip>
                        <Tooltip text="Loop" />
                    </tooltip>
                </ToggleButton>
            </HBox>
        </VBox>
    </bottom>

</BorderPane>
